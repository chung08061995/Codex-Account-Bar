<Window x:Class="CodexAccountBar.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Codex Account Bar" Width="520" Height="760" MinWidth="460" MinHeight="600" Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
 <Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="20">
   <Grid Margin="0,4,0,18"><StackPanel><TextBlock Text="Codex Accounts" FontSize="26" FontWeight="Bold"/><TextBlock Foreground="{StaticResource Muted}" FontSize="14" Margin="0,3,0,0"><Run Text="{Binding Accounts.Count}"/><Run Text=" saved / Windows DPAPI secured"/></TextBlock></StackPanel><Button Style="{StaticResource ActionButton}" HorizontalAlignment="Right" Padding="12,8" Click="Settings_Click">⚙</Button></Grid>
   <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,0,14"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="9Router service" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="{Binding RouterDetail}" Foreground="{StaticResource Muted}" Margin="0,4,12,0" TextWrapping="Wrap"/></StackPanel><CheckBox Grid.Column="1" Style="{StaticResource Toggle}" IsChecked="{Binding RouterRunning,Mode=OneWay}" IsEnabled="{Binding RouterCanToggle}" Click="RouterToggle_Click" VerticalAlignment="Center"/></Grid></Border>
   <Border Background="#252017" BorderBrush="#725028" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12" Visibility="{Binding MessageVisibility}"><TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#FFD09A"/></Border>
   <ItemsControl ItemsSource="{Binding Accounts}"><ItemsControl.ItemTemplate><DataTemplate>
    <Border Background="{StaticResource Surface}" BorderBrush="{Binding IsActive,Converter={StaticResource ActiveBorderConverter}}" BorderThickness="1.5" CornerRadius="14" Padding="16" Margin="0,0,0,12"><StackPanel>
     <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal"><Border Width="44" Height="44" CornerRadius="12" Background="#12373A" Margin="0,0,12,0"><TextBlock Text="●" Foreground="{StaticResource Teal}" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel VerticalAlignment="Center"><TextBlock Text="{Binding Email}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="300"/><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Plan}" Foreground="{StaticResource Muted}"/><TextBlock Text="  Current" Foreground="{StaticResource Green}" FontWeight="Bold" Visibility="{Binding IsActive,Converter={StaticResource BoolVisibilityConverter}}"/></StackPanel></StackPanel></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Style="{StaticResource ActionButton}" Padding="10,7" Margin="4,0" Tag="{Binding}" Click="Switch_Click">↻</Button><Button Style="{StaticResource ActionButton}" Padding="10,7" Margin="4,0" Tag="{Binding}" Click="Remove_Click">⋯</Button></StackPanel></Grid>
     <Grid Margin="0,16,0,4"><TextBlock Text="Session" FontWeight="SemiBold"/><TextBlock HorizontalAlignment="Right" Foreground="{StaticResource Muted}"><Run Text="{Binding SessionLeft,StringFormat={}{0:0}}"/><Run Text="% left"/></TextBlock></Grid><ProgressBar Value="{Binding SessionUsed}" Maximum="100" Height="8" Foreground="{StaticResource Orange}" Background="#303536" BorderThickness="0"/><TextBlock Text="{Binding SessionReset}" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,5,0,8"/>
     <Grid Margin="0,2,0,4"><TextBlock Text="Weekly" FontWeight="SemiBold"/><TextBlock HorizontalAlignment="Right" Foreground="{StaticResource Muted}"><Run Text="{Binding WeeklyLeft,StringFormat={}{0:0}}"/><Run Text="% left"/></TextBlock></Grid><ProgressBar Value="{Binding WeeklyUsed}" Maximum="100" Height="8" Foreground="{StaticResource Teal}" Background="#303536" BorderThickness="0"/>
    </StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
   <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="14" Padding="18" Visibility="{Binding EmptyVisibility}"><StackPanel><TextBlock Text="No Codex accounts saved" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Import the account Codex uses now, or add another with browser sign-in." Foreground="{StaticResource Muted}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0"/></StackPanel></Border>
  </StackPanel></ScrollViewer>
  <Border Grid.Row="1" Background="#191C1D" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="12"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Button Style="{StaticResource ActionButton}" Margin="0,0,6,0" Click="Add_Click">＋ Add</Button><Button Grid.Column="1" Style="{StaticResource ActionButton}" Margin="6,0" Click="Refresh_Click">↻ Refresh</Button><Button Grid.Column="2" Style="{StaticResource ActionButton}" Margin="6,0,0,0" Click="Hide_Click">— Hide</Button></Grid></Border>
 </Grid>
</Window>
